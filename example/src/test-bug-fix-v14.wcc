<script>
import { defineComponent, signal } from 'wcc'

export default defineComponent({
  tag: 'test-bug-fix-v14',
})

const count = signal(0)

// Función SIN parámetros - esto era el bug en v0.13.0
function getCount() {
  return count()
}

function increment() {
  count.set(count() + 1)
}

function decrement() {
  count.set(count() - 1)
}
</script>

<template>
  <div class="bug-fix-test">
    <h3>🐛 Test Bug Fix v0.14.0 - Funciones sin Parámetros</h3>
    
    <div class="description">
      <p><strong>Bug #1 (v0.13.0):</strong> Las funciones sin parámetros en templates como <code>getCount()</code> no funcionaban.</p>
      <p><strong>Workaround anterior:</strong> Usar <code>computed()</code> en su lugar.</p>
      <p><strong>Test actual:</strong> Verificar si v0.14.0 corrigió este bug.</p>
    </div>

    <div class="controls">
      <button @click="decrement">-1</button>
      <button @click="increment">+1</button>
    </div>

    <div class="results">
      <div class="result-item">
        <h4>Método 1: Signal directo (SIEMPRE funcionó)</h4>
        <p class="value">{{count()}}</p>
      </div>

      <div class="result-item">
        <h4>Método 2: Función sin parámetros getCount()</h4>
        <p class="value">{{getCount()}}</p>
        <p class="status" id="status-func">Estado: Esperando...</p>
      </div>
    </div>

    <div class="verdict" id="verdict">
      <h4>Veredicto:</h4>
      <p>Si ambos valores son iguales y se actualizan al hacer click → ✅ BUG CORREGIDO</p>
      <p>Si hay error o los valores no coinciden → ❌ BUG PERSISTE</p>
    </div>
  </div>
</template>

