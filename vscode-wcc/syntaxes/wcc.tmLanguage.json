{
  "name": "WCC",
  "scopeName": "source.wcc",
  "patterns": [
    { "include": "#script-block-ts" },
    { "include": "#script-block-js" },
    { "include": "#template-block" },
    { "include": "#style-block" },
    { "include": "#comment" }
  ],
  "repository": {
    "comment": {
      "begin": "<!--",
      "end": "-->",
      "name": "comment.block.html"
    },

    "script-block-ts": {
      "begin": "(<)(script)(\\s+lang\\s*=\\s*[\"']ts[\"'])(\\s*[^>]*)?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "entity.other.attribute-name.html" },
        "4": { "name": "entity.other.attribute-name.html" },
        "5": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "source.ts",
      "patterns": [
        { "include": "source.ts" }
      ]
    },

    "script-block-js": {
      "begin": "(<)(script)(\\s*[^>]*)?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "entity.other.attribute-name.html" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "source.js",
      "patterns": [
        { "include": "source.js" }
      ]
    },

    "template-block": {
      "begin": "(<)(template)(\\s*[^>]*)?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "entity.other.attribute-name.html" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(template)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "text.html.basic",
      "patterns": [
        { "include": "text.html.basic" }
      ]
    },

    "style-block": {
      "begin": "(<)(style)(\\s*[^>]*)?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "entity.other.attribute-name.html" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "source.css",
      "patterns": [
        { "include": "source.css" }
      ]
    }
  }
}
