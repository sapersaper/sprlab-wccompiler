{
  "name": "wcc-language",
  "displayName": "WCC Language Support",
  "description": "Syntax highlighting and intellisense for wcCompiler Single File Components (.wcc)",
  "version": "0.1.0",
  "publisher": "sprlab",
  "license": "MIT",
  "icon": "icons/wcc-icon.svg",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:wcc"
  ],
  "contributes": {
    "languages": [
      {
        "id": "wcc",
        "aliases": ["WCC", "wcc"],
        "extensions": [".wcc"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/wcc-file.svg",
          "dark": "./icons/wcc-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "wcc",
        "scopeName": "source.wcc",
        "path": "./syntaxes/wcc.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "source.ts": "typescript",
          "text.html.basic": "html",
          "source.css": "css"
        }
      }
    ]
  },
  "dependencies": {
    "@volar/vscode": "~2.4.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}
