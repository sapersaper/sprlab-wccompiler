{
  "name": "@sprlab/wccompiler",
  "version": "0.16.25",
  "description": "Zero-runtime compiler that transforms .wcc single-file components into native web components with signals-based reactivity",
  "type": "module",
  "exports": {
    ".": "./lib/compiler.js",
    "./integrations/vue": "./integrations/vue.js",
    "./integrations/react": "./integrations/react.js",
    "./integrations/angular": "./integrations/angular.js",
    "./adapters/vue": "./adapters/vue.js",
    "./adapters/angular": {
      "types": "./adapters/angular-compiled/angular.d.ts",
      "default": "./adapters/angular-compiled/angular.mjs"
    },
    "./adapters/react": "./adapters/react.js"
  },
  "bin": {
    "wcc": "./bin/wcc.js"
  },
  "files": [
    "bin/",
    "lib/*.js",
    "!lib/*.test.js",
    "integrations/",
    "adapters/",
    "types/",
    "README.md"
  ],
  "types": "./types/wcc.d.ts",
  "scripts": {
    "test": "vitest --run",
    "typecheck": "tsc --project jsconfig.json --noEmit"
  },
  "keywords": [
    "web-components",
    "compiler",
    "custom-elements",
    "zero-runtime",
    "signals",
    "native"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.27.0",
    "esbuild": "^0.27.0",
    "linkedom": "^0.18.12"
  },
  "peerDependencies": {
    "@angular/core": ">=14.0.0",
    "@vitejs/plugin-vue": ">=4.0.0",
    "react": ">=18.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "fast-check": "^4.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.1"
  },
  "volta": {
    "node": "24.0.0",
    "yarn": "4.12.0"
  }
}
