{
  "name": "@sprlab/wccompiler",
  "version": "0.5.10",
  "description": "Zero-runtime compiler that transforms .wcc single-file components into native web components with signals-based reactivity",
  "type": "module",
  "bin": {
    "wcc": "./bin/wcc.js"
  },
  "files": [
    "bin/",
    "lib/*.js",
    "!lib/*.test.js",
    "types/",
    "README.md"
  ],
  "types": "./types/wcc.d.ts",
  "scripts": {
    "test": "vitest --run",
    "typecheck": "tsc --project jsconfig.json --noEmit"
  },
  "keywords": [
    "web-components",
    "compiler",
    "custom-elements",
    "zero-runtime",
    "signals",
    "native"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "esbuild": "^0.27.0",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "fast-check": "^4.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.1"
  },
  "volta": {
    "node": "24.0.0",
    "yarn": "4.12.0"
  }
}
