    "type": "git",
    "url": ""
  },
  "dependencies": {
    "jsdom": "^29.0.2"
  },
  "devDependencies": {
    "fast-check": "^4.1.1",
    "vitest": "^3.2.1"
  },
  "volta": {
    "node": "24.0.0",
    "yarn": "4.12.0"
  }
}
