{
  "name": "@sprlab/wccompiler",
  "version": "0.0.3",
  "description": "Zero-runtime compiler that transforms .html files with Vue-like syntax into 100% native web components",
  "type": "module",
  "bin": {
    "wcc": "./bin/wcc.js"
  },
  "files": [
    "bin/",
    "lib/*.js",
    "!lib/*.test.js",
